import { Button, VerticalBox, HorizontalBox, GroupBox, Slider,
         Switch, ComboBox, ProgressIndicator, StandardButton,
         Palette, ScrollView, ListView } from "std-widgets.slint";

export struct SinkInputRow {
    id: int,
    name: string,
    route: string,  // "game", "chat", or ""
}

export struct RouteRule {
    app-name: string,
    route: string,
}

// ---------------------------------------------------------------------------
// Sidebar tab button
// ---------------------------------------------------------------------------

component TabButton inherits Rectangle {
    in property <string> label;
    in property <bool>   active;
    callback clicked;

    background: active ? Palette.accent-background : transparent;
    border-radius: 6px;

    TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: label;
        color: active ? Palette.accent-foreground : Palette.foreground;
        font-size: 13px;
        font-weight: active ? 700 : 400;
        padding-top: 10px;
        padding-bottom: 10px;
        padding-left: 16px;
        padding-right: 16px;
    }

    height: 40px;
}

// ---------------------------------------------------------------------------
// Device tab
// ---------------------------------------------------------------------------

component DeviceTab inherits ScrollView {
    in property <bool>       connected;
    in property <int>        battery-pct;
    in property <bool>       charging;
    in-out property <bool>   thx-enabled;
    in-out property <bool>   anc-enabled;
    in property <int>        anc-level;
    in property <int>        power-savings;

    callback set-thx(bool);
    callback set-anc(bool, int);
    callback set-power-savings(int);

    VerticalBox {
    width: parent.viewport-width;
    padding: 24px;
    spacing: 16px;
    alignment: start;

    // Connection + battery
    GroupBox {
        title: "Status";
        VerticalBox {
            spacing: 8px;
            HorizontalBox {
                Text { text: "Connection:"; color: Palette.foreground; font-weight: 600; }
                Text {
                    text: connected ? "Connected" : "Disconnected";
                    color: connected ? #4caf50 : #f44336;
                }
            }
            if connected: HorizontalBox {
                Text { text: "Battery:"; color: Palette.foreground; font-weight: 600; }
                ProgressIndicator {
                    progress: battery-pct > 100 ? 0.0 : battery-pct / 100.0;
                    width: 120px;
                }
                Text {
                    text: battery-pct > 100 ? "--" :
                          charging ? battery-pct + "% (charging)" : battery-pct + "%";
                    color: Palette.foreground;
                }
            }
        }
    }

    // Audio toggles
    if connected: GroupBox {
        title: "Audio";
        VerticalBox {
            spacing: 12px;
            HorizontalBox {
                Text { text: "THX Spatial Audio"; color: Palette.foreground; vertical-alignment: center; }
                Switch {
                    checked <=> thx-enabled;
                    toggled => { set-thx(self.checked); }
                }
            }
            HorizontalBox {
                Text { text: "Active Noise Cancellation"; color: Palette.foreground; vertical-alignment: center; }
                Switch {
                    checked <=> anc-enabled;
                    toggled => { set-anc(self.checked, anc-level); }
                }
            }
            if anc-enabled: HorizontalBox {
                Text { text: "ANC Level (1–4):"; color: Palette.foreground; vertical-alignment: center; }
                Slider {
                    minimum: 1;
                    maximum: 4;
                    value: anc-level;
                    step: 1;
                    changed(v) => { set-anc(true, round(v)); }
                    width: 150px;
                }
                Text { text: anc-level; color: Palette.foreground; }
            }
        }
    }

    // Power savings
    if connected: GroupBox {
        title: "Power";
        HorizontalBox {
            Text { text: "Auto-shutoff:"; color: Palette.foreground; vertical-alignment: center; }
            ComboBox {
                model: ["Off", "15 min", "30 min", "45 min", "60 min"];
                current-index: {
                    power-savings == 0  ? 0 :
                    power-savings == 15 ? 1 :
                    power-savings == 30 ? 2 :
                    power-savings == 45 ? 3 : 4
                };
                selected(s) => {
                    set-power-savings(
                        self.current-index == 0 ? 0  :
                        self.current-index == 1 ? 15 :
                        self.current-index == 2 ? 30 :
                        self.current-index == 3 ? 45 : 60
                    );
                }
            }
        }
    }

    } // VerticalBox
}

// ---------------------------------------------------------------------------
// Mic tab
// ---------------------------------------------------------------------------

component MicTab inherits ScrollView {
    in property <bool> connected;
    in property <int>  sidetone;

    callback set-sidetone(int);

    VerticalBox {
    width: parent.viewport-width;
    padding: 24px;
    spacing: 16px;
    alignment: start;

    GroupBox {
        title: "Sidetone";
        VerticalBox {
            spacing: 8px;
            Text {
                text: "Hear your own voice in the headset (0 = off, 15 = max)";
                color: Palette.foreground;
                font-size: 11px;
                wrap: word-wrap;
            }
            HorizontalBox {
                Text { text: "0"; color: Palette.foreground; }
                Slider {
                    enabled: connected;
                    minimum: 0;
                    maximum: 15;
                    value: sidetone;
                    step: 1;
                    released(v) => { set-sidetone(round(v)); }
                    horizontal-stretch: 1;
                }
                Text { text: "15"; color: Palette.foreground; }
                Text { text: sidetone; color: Palette.accent-background; font-weight: 700; min-width: 24px; }
            }
        }
    }

    } // VerticalBox
}

// ---------------------------------------------------------------------------
// Audio tab
// ---------------------------------------------------------------------------

component AudioTab inherits ScrollView {
    in property <bool> connected;
    in property <int>  eq-preset;
    callback set-eq(int);

    VerticalBox {
    width: parent.viewport-width;
    padding: 24px;
    spacing: 16px;
    alignment: start;

    GroupBox {
        title: "EQ Preset";
        VerticalBox {
            spacing: 8px;
            Text {
                text: "Select a preset. Custom band editing coming soon.";
                color: Palette.foreground;
                font-size: 11px;
            }

            HorizontalBox {
                spacing: 8px;
                for name[i] in ["Default", "Game", "Movie", "Music", "CS2"]: Button {
                    text: name;
                    enabled: connected;
                    primary: eq-preset == i;
                    clicked => { set-eq(i); }
                }
            }

            Text {
                text: {
                    eq-preset == 0 ? "Default — flat, no EQ applied" :
                    eq-preset == 1 ? "Game — bass and mid boost for immersive game audio" :
                    eq-preset == 2 ? "Movie — V-shape: boosted bass and treble, scooped mids" :
                    eq-preset == 3 ? "Music — mild bass boost, reduced harshness" :
                    eq-preset == 4 ? "Counter-Strike 2 — presence boost, lifted highs for footstep clarity" :
                    "Custom preset (band data not yet captured)"
                };
                color: Palette.foreground;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
    }

    } // VerticalBox
}

// ---------------------------------------------------------------------------
// Routing tab
// ---------------------------------------------------------------------------

component RoutingTab inherits ScrollView {
    in property <bool>           connected;
    in property <[SinkInputRow]> streams;
    in property <[RouteRule]>    rules;
    in property <int>            game-chat-mix;

    callback set-route(int, string);   // (sink_input_id, "game"/"chat"/"")
    callback remove-rule(string);      // app_name
    callback refresh();
    callback set-game-chat-mix(int);

    VerticalBox {
    width: parent.viewport-width;
    padding: 24px;
    spacing: 16px;
    alignment: start;

    // Game / Chat mix
    if connected: GroupBox {
        title: "Game / Chat Mix";
        VerticalBox {
            spacing: 8px;
            HorizontalBox {
                spacing: 8px;
                Text { text: "Chat"; color: Palette.foreground; vertical-alignment: center; }
                Slider {
                    minimum: 0;
                    maximum: 100;
                    value: game-chat-mix;
                    step: 1;
                    changed(v) => { set-game-chat-mix(round(v)); }
                    horizontal-stretch: 1;
                }
                Text { text: "Game"; color: Palette.foreground; vertical-alignment: center; }
            }
            Text {
                text: game-chat-mix + "% Game / " + (100 - game-chat-mix) + "% Chat";
                color: Palette.accent-background;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
    }

    // Active streams
    GroupBox {
        title: "Active Audio Streams";
        VerticalBox {
            spacing: 8px;
            HorizontalBox {
                Text {
                    text: "Route each playing app to a sink. Rules are saved automatically.";
                    color: Palette.foreground;
                    font-size: 11px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    wrap: word-wrap;
                }
                Button {
                    text: "Refresh";
                    clicked => { root.refresh(); }
                }
            }
            if streams.length == 0: Text {
                text: connected ? "No audio streams active." : "Headset not connected.";
                color: Palette.foreground;
                font-size: 12px;
            }
            for stream in streams: HorizontalBox {
                spacing: 8px;
                Text {
                    text: stream.name;
                    color: Palette.foreground;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Button {
                    text: "Game";
                    primary: stream.route == "game";
                    enabled: connected;
                    clicked => { set-route(stream.id, "game"); }
                }
                Button {
                    text: "Chat";
                    primary: stream.route == "chat";
                    enabled: connected;
                    clicked => { set-route(stream.id, "chat"); }
                }
                Button {
                    text: "Default";
                    primary: stream.route == "";
                    enabled: connected;
                    clicked => { set-route(stream.id, ""); }
                }
            }
        }
    }

    // Saved rules
    GroupBox {
        title: "Saved Rules";
        VerticalBox {
            spacing: 6px;
            if rules.length == 0: Text {
                text: "No rules saved yet. Assign a stream above to create one.";
                color: Palette.foreground;
                font-size: 11px;
            }
            for rule in rules: HorizontalBox {
                spacing: 8px;
                Text {
                    text: rule.app-name;
                    color: Palette.foreground;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Text {
                    text: rule.route == "game" ? "Game" : "Chat";
                    color: Palette.accent-background;
                    font-weight: 700;
                    vertical-alignment: center;
                    min-width: 40px;
                }
                Button {
                    text: "Remove";
                    clicked => { remove-rule(rule.app-name); }
                }
            }
        }
    }

    } // VerticalBox
}

// ---------------------------------------------------------------------------
// Stub tab
// ---------------------------------------------------------------------------

component StubTab inherits VerticalBox {
    in property <string> name;
    padding: 24px;
    Text {
        text: name + " — coming soon";
        color: Palette.foreground;
        font-size: 16px;
        horizontal-alignment: center;
        vertical-alignment: center;
        vertical-stretch: 1;
    }
}

// ---------------------------------------------------------------------------
// Advanced tab
// ---------------------------------------------------------------------------

component AdvancedTab inherits ScrollView {
    in property <bool>   sinks-active;
    in property <string> daemon-status;  // "active", "inactive", "failed", ...

    callback teardown-sinks();
    callback rebuild-sinks();
    callback start-daemon();
    callback stop-daemon();
    callback restart-daemon();

    VerticalBox {
    width: parent.viewport-width;
    padding: 24px;
    spacing: 16px;
    alignment: start;

    GroupBox {
        title: "Daemon (blacksharkd)";
        VerticalBox {
            spacing: 12px;
            HorizontalBox {
                spacing: 8px;
                Text { text: "Status:"; font-weight: 600; color: Palette.foreground; }
                Text {
                    text: daemon-status;
                    color: daemon-status == "active" ? #4caf50
                         : daemon-status == "failed"  ? #f44336
                         : #888888;
                }
            }
            HorizontalBox {
                spacing: 8px;
                alignment: start;
                Button {
                    text: "Start";
                    enabled: daemon-status != "active";
                    clicked => { start-daemon(); }
                }
                Button {
                    text: "Stop";
                    enabled: daemon-status == "active";
                    clicked => { stop-daemon(); }
                }
                Button {
                    text: "Restart";
                    clicked => { restart-daemon(); }
                }
            }
        }
    }

    GroupBox {
        title: "PipeWire Sinks";
        VerticalBox {
            spacing: 12px;
            HorizontalBox {
                spacing: 8px;
                Text { text: "Status:"; font-weight: 600; color: Palette.foreground; }
                Text {
                    text: sinks-active ? "Active" : "Inactive";
                    color: sinks-active ? #4caf50 : #f44336;
                }
            }
            Text {
                text: "Tear down and rebuild the blackshark-game / blackshark-chat PipeWire sinks. Use this if audio routing stops working.";
                color: Palette.foreground;
                wrap: word-wrap;
            }
            HorizontalBox {
                spacing: 8px;
                alignment: start;
                Button {
                    text: "Tear Down";
                    clicked => { teardown-sinks(); }
                }
                Button {
                    text: "Rebuild";
                    clicked => { rebuild-sinks(); }
                }
            }
        }
    }

    } // VerticalBox
}

// ---------------------------------------------------------------------------
// Main window
// ---------------------------------------------------------------------------

export component MainWindow inherits Window {
    title: "BlackShark V3 Pro";
    min-width: 640px;
    min-height: 480px;
    preferred-width: 800px;
    preferred-height: 540px;
    background: Palette.background;

    // State
    in-out property <int>  active-tab: 0;
    in property <bool>       connected;
    in property <int>        battery-pct;
    in property <bool>       charging;
    in property <int>        eq-preset;
    in property <int>        game-chat-mix;
    in property <int>        sidetone;
    in-out property <bool>   thx-enabled;
    in-out property <bool>   anc-enabled;
    in property <int>        anc-level;
    in property <int>        power-savings;

    in property <[SinkInputRow]> streams;
    in property <[RouteRule]>   rules;
    in property <bool>          sinks-active;
    in property <string>        daemon-status;

    // Callbacks → Rust
    callback set-eq(int);
    callback set-game-chat-mix(int);
    callback set-sidetone(int);
    callback set-route(int, string);
    callback remove-rule(string);
    callback refresh-streams();
    callback set-thx(bool);
    callback set-anc(bool, int);
    callback set-power-savings(int);
    callback teardown-sinks();
    callback rebuild-sinks();
    callback start-daemon();
    callback stop-daemon();
    callback restart-daemon();

    HorizontalBox {
        padding: 0;
        spacing: 0;

        // Sidebar
        Rectangle {
            width: 160px;
            background: Palette.alternate-background;

            VerticalBox {
                padding-top: 12px;
                padding-bottom: 12px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;

                Text {
                    text: "BlackShark";
                    font-size: 15px;
                    font-weight: 700;
                    color: Palette.foreground;
                    padding-bottom: 12px;
                    padding-left: 8px;
                }

                TabButton { label: "Device";     active: active-tab == 0; clicked => { active-tab = 0; } }
                TabButton { label: "Audio";      active: active-tab == 1; clicked => { active-tab = 1; } }
                TabButton { label: "Mic";        active: active-tab == 2; clicked => { active-tab = 2; } }
                TabButton { label: "Routing";    active: active-tab == 3; clicked => { active-tab = 3; } }
                TabButton { label: "Automation"; active: active-tab == 4; clicked => { active-tab = 4; } }
                TabButton { label: "Settings";   active: active-tab == 5; clicked => { active-tab = 5; } }
                TabButton { label: "Advanced";   active: active-tab == 6; clicked => { active-tab = 6; } }

                Rectangle { vertical-stretch: 1; }
            }
        }

        // Divider
        Rectangle { width: 1px; background: Palette.border; }

        // Content
        if active-tab == 0: DeviceTab {
            connected:     connected;
            battery-pct:   battery-pct;
            charging:      charging;
            thx-enabled <=> thx-enabled;
            anc-enabled <=> anc-enabled;
            anc-level:     anc-level;
            power-savings: power-savings;
            set-thx(v)       => { set-thx(v); }
            set-anc(e, l)    => { set-anc(e, l); }
            set-power-savings(m) => { set-power-savings(m); }
            horizontal-stretch: 1;
        }
        if active-tab == 1: AudioTab {
            connected: connected;
            eq-preset: eq-preset;
            set-eq(p) => { set-eq(p); }
            horizontal-stretch: 1;
        }
        if active-tab == 2: MicTab {
            connected: connected;
            sidetone:  sidetone;
            set-sidetone(v) => { set-sidetone(v); }
            horizontal-stretch: 1;
        }
        if active-tab == 3: RoutingTab {
            connected:      connected;
            streams:        streams;
            rules:          rules;
            game-chat-mix:  game-chat-mix;
            set-route(id, r)       => { set-route(id, r); }
            remove-rule(name)      => { remove-rule(name); }
            refresh()              => { refresh-streams(); }
            set-game-chat-mix(m)   => { set-game-chat-mix(m); }
            horizontal-stretch: 1;
        }
        if active-tab == 4: StubTab { name: "Automation"; horizontal-stretch: 1; }
        if active-tab == 5: StubTab { name: "Settings";   horizontal-stretch: 1; }
        if active-tab == 6: AdvancedTab {
            sinks-active:     sinks-active;
            daemon-status:    daemon-status;
            teardown-sinks()  => { teardown-sinks(); }
            rebuild-sinks()   => { rebuild-sinks(); }
            start-daemon()    => { start-daemon(); }
            stop-daemon()     => { stop-daemon(); }
            restart-daemon()  => { restart-daemon(); }
            horizontal-stretch: 1;
        }
    }
}
